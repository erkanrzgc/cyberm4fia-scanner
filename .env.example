# CYBERM4FIA VulnScanner Environment Configuration
# Copy this file to .env and fill in your values
# Do NOT commit .env to version control!

# ── Shodan API ──
SHODAN_API_KEY=

# ── OOB (Out-of-Band) Server ──
OOB_SERVER=interact.sh

# ── Proxy Configuration ──
# HTTP_PROXY=http://127.0.0.1:8080
# SOCKS5_PROXY=socks5://127.0.0.1:9050

# ── Scan Defaults ──
DEFAULT_THREADS=10
DEFAULT_DELAY=0.5
VERIFY_SSL=false

# ── API Server ──
API_HOST=0.0.0.0
API_PORT=8080
