# CYBERM4FIA VulnScanner Environment Configuration
# Copy this file to .env and fill in your values
# Do NOT commit .env to version control!

# ── NVIDIA NIM API (Primary AI Backend) ──
# Get your key at https://build.nvidia.com/
NVIDIA_API_KEY=REDACTED-OLD-NVIDIA-KEY-REVOKED

# ── Shodan API ──
SHODAN_API_KEY=

# ── WatchStack PoC Intelligence ──
# Get your free API key at https://watchstack.io (30 req/min)
WATCHSTACK_API_KEY=

# ── GitHub API (higher rate limits for PoC search) ──
GITHUB_TOKEN=

# ── OOB (Out-of-Band) Server ──
OOB_SERVER=interact.sh

# ── Proxy Configuration ──
# HTTP_PROXY=http://127.0.0.1:8080
# SOCKS5_PROXY=socks5://127.0.0.1:9050

# ── Scan Defaults ──
DEFAULT_THREADS=10
DEFAULT_DELAY=0.5
VERIFY_SSL=false

# ── API Server ──
API_HOST=0.0.0.0
API_PORT=8080
